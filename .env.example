# Backend
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://insta_link:insta_link_secret@localhost:5432/insta_link

# Redis
REDIS_URL=redis://localhost:6379

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_GRAPH_API_URL=https://graph.instagram.com
META_GRAPH_API_VERSION=v21.0

# Frontend (for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Rate Limits (Meta allows ~200 API calls/hour per user)
DM_RATE_LIMIT_PER_HOUR=100
MAX_QUEUE_DELAY_SEC=20
MIN_QUEUE_DELAY_SEC=5
